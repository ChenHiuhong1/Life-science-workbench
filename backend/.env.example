# Science Workbench environment example.
# Copy this file to the app .env file and fill in your own values.
#
# LLM providers using an OpenAI-compatible API:
# GLM: https://open.bigmodel.cn/api/paas/v4/
# DeepSeek: https://api.deepseek.com/v1
# Kimi: https://api.moonshot.cn/v1
# OpenAI: https://api.openai.com/v1
# Local vLLM/Ollama: http://localhost:11434/v1
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
LLM_API_KEY=
LLM_MODEL=glm-4-plus
REASONING_EFFORT=auto

# Code sandbox
SANDBOX_TIMEOUT=120
PYTHON_EXECUTABLE=python
R_EXECUTABLE=Rscript

# Backend service
HOST=127.0.0.1
PORT=8000
